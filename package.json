{
  "name": "testflow-api",
  "version": "1.0.0",
  "description": "API REST para gestao de testes de software",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "mocha \"test/**/*.test.js\" --require dotenv/config --timeout 10000",
    "test:report": "mocha \"test/**/*.test.js\" --require dotenv/config --reporter mochawesome --reporter-options reportDir=qa/reports,reportFilename=mochawesome-report,quiet=true,overwrite=true --timeout 10000"
  },
  "keywords": [
    "express",
    "jwt",
    "swagger",
    "api",
    "portfolio"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2"
  }
}
